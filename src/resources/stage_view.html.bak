<html>
	<head>
		<title>
			ProjectOn Web Remote
		</title>

		<style>
			body {
				overflow: hidden;
				margin: 0;
				padding: 0;
				background: black;
			}

			#lyric_container {
				width: 100%;
				height: 100%;
				display: table;
			}

			#lyric_display {
				text-align: center;
				display: table-cell;
				vertical-align: middle;
				font-family: "Arial";
				font-weight: bold;
				line-height: 150%;
				color: white;
				overflow: hidden;
			}

            #image_display {
                position: absolute;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                transform: translateZ(0);           /* Promote to its own compositor layer */
                z-index: 1;
                will-change: transform, contents;   /* Hint frequent changes */
                image-rendering: crisp-edges;       /* Skip smoothing if acceptable */
                backface-visibility: hidden;        /* Sometimes helps GPU upload */
            }
            #slide_number {
                position: absolute;
                width: 100vw;
                top: 94vh;
                margin-right: 1vw;
                z-index: 10;
                font-family: "Arial";
                font-weight: bold;
                font-size: 5vh;
                color: #ffffff;
                text-shadow: 5px 5px 5px black;
                text-align: right;
            }
        </style>

	</head>

    <body>
		<div id="lyric_container">
			<div id="lyric_display"></div>
		</div>
        <div id="image_container">
            <img id="image_display">
        </div>
        <div id="slide_number"></div>
    </body>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.0.1/socket.io.js" integrity="sha512-q/dWJ3kcmjBLU4Qc47E4A9kTB4m3wuTY7vkFJDTZKjTs8jhyGQnaUrxa0Ytd0ssMZhbNua9hE+E7Qv1j+DyZwA==" crossorigin="anonymous"></script>
	<script type="text/javascript" charset="utf-8">
		var socket = io();

		//function for updating the stage display using text
		socket.on('update_stage', function(text) {
			document.getElementById("image_display").src = "";
			html = text[0];
			font_size = text[1];
			slide_number = text[2];
			document.getElementById("lyric_display").innerHTML = html;
			document.getElementById("lyric_display").style.fontSize = font_size + 'px';
			document.getElementById("slide_number").innerHTML = slide_number;
		});

        let currentObjectURL = null;
        // Function for updating the stage display using binary image data
		socket.on('update_display', async (data) => {
			const binaryData = data[0];
			const slide_number = data[1];

			// 1. Immediately revoke the previous URL (if any)
			if (currentObjectURL) {
				URL.revokeObjectURL(currentObjectURL);
				currentObjectURL = null;
			}

			// 2. Clean DOM quickly
			document.getElementById("lyric_display").innerHTML = "";

			const startTime = performance.now();

			// 3. Create fresh blob + url
			const blob = new Blob([binaryData], { type: 'image/jpeg' });
			const url = URL.createObjectURL(blob);
			currentObjectURL = url;   // remember for next time

			const display = document.getElementById('image_display');

			try {
				display.onload = () => {
					display.onload = null;  // clean up
				};

				display.onerror = () => {
					console.error('Image load failed');
					display.onerror = null;
				};

				// This triggers decode & display in one step
				display.src = url;

				// Only set dimensions/style when they actually change (optimization)
				// You can compare with previous values if you store them
				display.style.width  = '100vw';
				display.style.height = '100vh';
				display.style.objectFit = 'contain';

			} catch (err) {
				console.error('Unexpected error:', err);
				// Fallback — but prefer not to use a new Image() here
				display.src = url;  // still try
			}

			document.getElementById("slide_number").innerHTML = `<span>${slide_number}</span>`;
		});
	</script>
</html>